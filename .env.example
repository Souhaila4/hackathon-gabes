# Copier vers .env et adapter (ne jamais committer .env avec des secrets réels).

FLASK_ENV=production
PORT=8080

SECRET_KEY=change-me-long-random
JWT_SECRET_KEY=change-me-other-long-random
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# MongoDB — Atlas exemple : utilisez retryWrites pour les clusters Atlas
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=phosalert
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=phosalert

REQUIRE_JWT=false
SWAGGER_ENABLED=true

# Optionnel
CLAUDE_API_KEY=
